# Discord application (client) id — dev portal → General Information.
# Required for the SDK handshake; copy this file to `.env` and fill it in.
VITE_DISCORD_CLIENT_ID=

# Optional: override the API base. Defaults to same-origin `/api`, which the
# Vite dev proxy (and Discord's proxy in production) routes to leaf-server.
# VITE_API_BASE=/api
